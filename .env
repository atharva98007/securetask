# Copy this file to .env and adjust values for your environment.

ENVIRONMENT=development

# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./securetask.db

# Postgres example:
# DATABASE_URL=postgresql://securetask:securetask@localhost:5432/securetask

# MySQL example:
# DATABASE_URL=mysql+pymysql://securetask:securetask@localhost:3306/securetask

# Generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_super_secret_key_please_rotate
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["*"]
